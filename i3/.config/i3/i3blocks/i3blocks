command=$HOME/.config/i3/scripts/$BLOCK_NAME
separator_block_width=15

[window_title]
command=bash -c "$HOME/.config/i3/scripts/window_title right"
interval=once
signal=10

[battery2]
interval=60

[bandwidth]
label=
interval=2
color=#cfd9Cf

[temp]
label= 
command=sensors coretemp-isa-0000 | awk '/Physical/ { print $4  }'
interval=10


[volume]
label=
instance=Master
interval=once
signal=1
color=#CADDFF




[time]
command=LC_TIME=pl_PL.UTF-8 date +"%Y-%m-%d %a, %R"
color=#FFFFFF
interval=60
