command=$HOME/.config/i3/scripts/$BLOCK_NAME
separator_block_width=15

[window_title]
command=bash -c "$HOME/.config/i3/scripts/window_title left"
interval=once
signal=10


[pvolume]
label=VOL
instance=Master
interval=once
signal=1
color=#CADDFF


[time]
command=LC_TIME=pl_PL.UTF-8 date +"%Y-%m-%d %a, %R"
color=#FFFFFF
interval=60
